# ----------------------------------------------------------------------------
# target-market — environment configuration
# Copy this file to `.env` and fill in the values you need.
# The app runs out-of-the-box with only the defaults below (no external keys).
# ----------------------------------------------------------------------------

# Database (SQLite by default — a local file, no server required).
# For production, point this at Postgres, e.g.
#   DATABASE_URL="postgresql://user:pass@host:5432/target_market"
# and change `provider` in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Secret used to sign session cookies and magic-link tokens.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="dev-only-insecure-secret-change-me-please-0000000000"

# Public base URL of the app (used to build magic links).
APP_URL="http://localhost:3000"

# Only e-mail addresses on these domains may sign in (comma separated).
ALLOWED_EMAIL_DOMAINS="oss.ventures"

# --- Claude (optional) -------------------------------------------------------
# If unset, the app falls back to a built-in heuristic analyzer so everything
# still works for demos. Set this to enable high-quality AI analysis & tagging.
ANTHROPIC_API_KEY=""
# Override the model if you like (defaults to a current Claude model).
ANTHROPIC_MODEL="claude-opus-4-8"

# --- Email delivery (optional) ----------------------------------------------
# Provider for sending magic links: "console" (default — prints the link to the
# server log) or "resend".
EMAIL_PROVIDER="console"
EMAIL_FROM="GTM Tool <gtm@oss.ventures>"
# Required only when EMAIL_PROVIDER="resend"
RESEND_API_KEY=""

# --- Map ---------------------------------------------------------------------
# MapLibre style URL. Default is OpenFreeMap (free, no API key required).
NEXT_PUBLIC_MAP_STYLE_URL="https://tiles.openfreemap.org/styles/liberty"

# --- Data ingestion ----------------------------------------------------------
# Overpass API endpoint used by the OpenStreetMap importer / in-app sync.
# The host must allow outbound HTTPS to this domain. Alternatives:
#   https://overpass.kumi.systems/api/interpreter
#   https://overpass.private.coffee/api/interpreter
OVERPASS_ENDPOINT="https://overpass-api.de/api/interpreter"
